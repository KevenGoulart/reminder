generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  Reminders     Reminder[] @relation("ReminderOwner")
}

model Reminder {
  id        String   @id @default(uuid())
  title     String
  date      DateTime
  recurring Boolean
  notifiedAt DateTime?
  relatedUsers String[]
  userId    String
  User      User     @relation("ReminderOwner", fields: [userId], references: [id])
}